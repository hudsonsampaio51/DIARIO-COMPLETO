{
  "entities": {
    "School": {
      "title": "School",
      "description": "School registration data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "state": { "type": "string" },
        "municipality": { "type": "string" },
        "address": { "type": "string" },
        "creationDecree": { "type": "string" },
        "authorization": { "type": "string" },
        "resolution": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "site": { "type": "string" },
        "blog": { "type": "string" },
        "schoolCode": { "type": "string" },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "state", "municipality", "schoolCode"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "secretary", "teacher", "supervisor"] },
        "schoolId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student registration data",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "cpf": { "type": "string" },
        "rg": { "type": "string" },
        "birthDate": { "type": "string" },
        "birthPlace": { "type": "string" },
        "contact": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "cep": { "type": "string" }
          }
        },
        "registrationNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "classId": { "type": "string" },
        "guardianFirstName": { "type": "string" },
        "guardianLastName": { "type": "string" },
        "guardianCpf": { "type": "string" },
        "guardianRg": { "type": "string" },
        "guardianContact": { "type": "string" }
      },
      "required": ["schoolId", "firstName", "lastName", "registrationNumber"]
    },
    "Staff": {
      "title": "Staff",
      "description": "School staff member",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "cpf": { "type": "string" },
        "rg": { "type": "string" },
        "birthDate": { "type": "string" },
        "birthPlace": { "type": "string" },
        "contact": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "cep": { "type": "string" }
          }
        },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["schoolId", "firstName", "lastName", "email", "role"]
    },
    "Class": {
      "title": "Class",
      "description": "School class/turma",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "year": { "type": "number" },
        "shift": { "type": "string", "enum": ["Matutino", "Vespertino", "Noturno", "Integral"] },
        "teacherId": { "type": "string" },
        "educationLevel": { "type": "string", "enum": ["Creche", "Educação Infantil", "Ensino Fundamental I", "Ensino Fundamental II"] }
      },
      "required": ["schoolId", "name", "grade", "year"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "sessionId": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "teacherId": { "type": "string" },
        "observations": { "type": "string" }
      },
      "required": ["schoolId", "classId", "studentId", "date", "status"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student grade record",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "period": { "type": "string" },
        "value": { "type": "number" },
        "teacherId": { "type": "string" }
      },
      "required": ["schoolId", "studentId", "classId", "period", "value"]
    },
    "Subject": {
      "title": "Subject",
      "description": "School subject for a specific class",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "classId": { "type": "string" },
        "workload": { "type": "number", "description": "Annual workload in hours" }
      },
      "required": ["schoolId", "name", "classId"]
    },
    "ClassSchedule": {
      "title": "ClassSchedule",
      "description": "Weekly schedule for a class",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "classId": { "type": "string" },
        "dayOfWeek": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "subjectId": { "type": "string" }
      },
      "required": ["schoolId", "classId", "dayOfWeek", "startTime", "endTime", "subjectId"]
    },
    "ClassSession": {
      "title": "ClassSession",
      "description": "Specific class date session",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "observations": { "type": "string" },
        "classHours": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["schoolId", "classId", "date"]
    },
    "Occurrence": {
      "title": "Occurrence",
      "description": "Student occurrence/incident record",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Indisciplina", "Elogio", "Outro"] },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["schoolId", "studentId", "classId", "date", "type", "description"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "School registrations"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff records"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Class records"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance logs"
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Grade records"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subject records"
    },
    "/schedules/{scheduleId}": {
      "schema": "ClassSchedule",
      "description": "Class schedule records"
    },
    "/classSessions/{sessionId}": {
      "schema": "ClassSession",
      "description": "Class session records"
    },
    "/occurrences/{occurrenceId}": {
      "schema": "Occurrence",
      "description": "Student occurrence records"
    }
  }
}
